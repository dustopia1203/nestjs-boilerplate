# Application config (validated by src/application/config/app.config.ts)

# HTTP port the Nest server binds to. Must be a positive integer.
# Optional — defaults to 3000.
PORT=3000

# Runtime environment. One of: development | production | test.
# Optional — defaults to development.
NODE_ENV=development

# Logger config (validated by src/application/config/logger.config.ts)

# Pino log level. One of: trace | debug | info | warn | error | fatal | silent.
# Optional — defaults to debug in development, info in production, silent in test.
# LOG_LEVEL=
